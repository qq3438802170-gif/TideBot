# ==========================================
# TideBot 环境变量配置模板
# 请复制此文件并重命名为 .env，然后填入你的真实凭证
# ==========================================

# 1. 数据库配置
# 默认使用异步 SQLite 引擎，存储在 data/db 目录下
DATABASE_URL=sqlite+aiosqlite:///data/db/tidebot.db

# 2. 模型 API Keys (按需填写)
OPENAI_API_KEY=sk-your-openai-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here
CLAUDE_API_KEY=your-claude-api-key-here
DEEPSEEK_API_KEY=your-deepseek-api-key-here
# 硅基流动或百炼等兼容 OpenAI 格式的服务，可以配置 BaseURL
CUSTOM_LLM_BASE_URL=https://api.siliconflow.cn/v1

# 3. 安全鉴权配置
# 用于签发给 App 端的 JWT 签名密钥，请务必修改为长随机字符串
APP_SECRET_KEY=replace_this_with_a_highly_secure_random_string_in_production
# Token 过期时间（天）
JWT_EXPIRATION_DAYS=30

# 4. 网络与穿透支持
# 可选：Cloudflare Tunnel Token (如果你需要自动化内网穿透 API 给手机端使用)
CF_TUNNEL_TOKEN=
