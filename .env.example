# --- 基础服务配置 ---
PROJECT_NAME="TideBot"
VERSION="1.0.0"
API_V1_STR="/api/v1"

# --- 安全与加密配置 ---
# 警告：生产环境请使用命令 `openssl rand -hex 32` 生成高强度密钥
SECRET_KEY="tidebot-core-super-cryptographic-secret-key-signature"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- 跨域配置 (JSON 格式数组) ---
BACKEND_CORS_ORIGINS='["http://localhost:3000", "http://localhost:5173", "http://127.0.0.1:5173"]'

# --- 数据持久化配置 ---
# 本地轻量化开发切换为: sqlite+aiosqlite:///./tidebot.db
DATABASE_URL="postgresql+asyncpg://postgres:password@localhost:5432/tidebot"
REDIS_URL="redis://localhost:6379/0"

# --- 微信 OpenClaw 桥接配置 ---
OPENCLAW_API_URL="http://localhost:8090"
OPENCLAW_SECRET="claw-bot-auth-token-string"
