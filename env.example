# ==========================================
# TideBot Environment Configuration Template
# ==========================================

# --- App Settings ---
APP_NAME=TideBot
APP_ENV=development  # development, testing, production
APP_DEBUG=true
API_V1_STR=/api/v1
HOST=0.0.0.0
PORT=8000

# --- Security ---
# 生成密钥: openssl rand -hex 32
SECRET_KEY=your_super_secret_key_here
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 days

# --- Database (SQLAlchemy compatible) ---
# SQLite 示例 (开发环境)
DATABASE_URL=sqlite+aiosqlite:///./tidebot.db
# PostgreSQL 示例 (生产环境推荐)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/tidebot

# --- AI Models API ---
# 不使用本地模型，配置云端 API 密钥
DEFAULT_LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-api-key
ANTHROPIC_API_KEY=sk-your-anthropic-api-key

# --- Built-in Tools Configuration ---
# 联网搜索底层工具配置
SEARCH_ENGINE_PROVIDER=tavily # duckduckgo, bing, tavily
SEARCH_API_KEY=your_search_api_key

# --- Plugin System ---
PLUGINS_DIR=src/tidebot/plugins
ENABLE_PLUGIN_SYSTEM=true